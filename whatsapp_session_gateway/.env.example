# PrimeyAcc WhatsApp Session Gateway
PORT=3100
HOST=127.0.0.1
LOG_LEVEL=info
# Persistent auth storage. Do not delete this folder unless you want to unlink WhatsApp.
WHATSAPP_SESSION_STORAGE_DIR=./storage/sessions
# Optional. If set, Django must send Authorization: Bearer <token>.
WHATSAPP_SESSION_GATEWAY_TOKEN=
